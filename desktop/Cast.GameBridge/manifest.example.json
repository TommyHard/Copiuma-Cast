{
  // Пример манифеста мода. Скопируйте рядом с модом (напр. в папку moonloader)
  // и замените события на реальные ключи из таблицы `events` вашего мода.
  // Транспорт socket → десктоп шлёт команды на 127.0.0.1:14888 (как в GTA SA).
  "manifestVersion": 1,
  "gameId": "gta_sa",
  "gameName": "GTA San Andreas — Flame Story",
  "modVersion": "1.0.0",
  "transport": "socket",
  "socketHost": "127.0.0.1",
  "socketPort": 14888,
  "fileName": "events.txt",

  "events": [
    {
      "id": "spawn_random_vehicle",
      "title": "Заспавнить машину",
      "description": "Появляется случайный транспорт рядом с игроком.",
      "category": "Транспорт",
      "costCoins": 50,
      "cooldownMs": 5000,
      "enabled": true,
      "params": []
    },
    {
      "id": "set_weather",
      "title": "Сменить погоду",
      "description": "Меняет погоду в игре.",
      "category": "Окружение",
      "costCoins": 20,
      "cooldownMs": 3000,
      "enabled": true,
      "params": [
        {
          "name": "weatherId",
          "title": "Погода",
          "type": "enum",
          "required": true,
          "enumValues": [ "sunny", "rain", "fog", "storm" ]
        }
      ]
    },
    {
      "id": "give_weapon",
      "title": "Выдать оружие",
      "description": "Даёт игроку оружие с патронами.",
      "category": "Оружие",
      "costCoins": 80,
      "cooldownMs": 8000,
      "enabled": true,
      "params": [
        { "name": "weaponId", "title": "Оружие", "type": "int", "required": true, "min": 1, "max": 46 },
        { "name": "ammo", "title": "Патроны", "type": "int", "required": false, "default": "100", "min": 1, "max": 9999 }
      ]
    }
  ]
}
