<Window x:Class="Cast.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Cast.Desktop.ViewModels"
        xmlns:views="clr-namespace:Cast.Desktop.Views"
        mc:Ignorable="d"
        Title="Copiuma.Cast" 
        Height="680" Width="960"
        Background="#000000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- VM → View маппинг -->
        <DataTemplate DataType="{x:Type vm:ModManagerViewModel}">
            <views:ModManagerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RoomViewModel}">
            <views:RoomView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LaunchViewModel}">
            <views:LaunchView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DebugViewModel}">
            <views:DebugView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid Style="{StaticResource AnimatedBackgroundStyle}">
            <Grid.Effect>
                <BlurEffect Radius="5" KernelType="Gaussian" />
            </Grid.Effect>
        </Grid>
        <!-- Login screen (shown when not logged in) -->
        <views:LoginView DataContext="{Binding}"
                         Visibility="{Binding IsLoggedIn, Converter={StaticResource InvertBoolToVis}}"/>

        <!-- Main shell (shown when logged in) -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Top: brand -->
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,24">
                        <TextBlock Text="{DynamicResource AppTitle}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock Text="{Binding Username}" FontSize="12"
                                   Foreground="{DynamicResource FgSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Bottom: logout + lang -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                        <Separator Background="{DynamicResource BorderBrush}" Margin="4,0,4,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <Button Content="EN" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding SwitchLanguageCommand}" CommandParameter="en"
                                    Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                            <Button Content="RU" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding SwitchLanguageCommand}" CommandParameter="ru"
                                    Padding="8,3" FontSize="11"/>
                        </StackPanel>
                        <Button Content="{DynamicResource Logout}" Style="{StaticResource SecondaryButton}"
                                Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch"
                                Padding="8,6" FontSize="12"/>
                    </StackPanel>

                    <!-- Nav items -->
                    <StackPanel Margin="8,0">
                        <RadioButton Content="{DynamicResource NavMods}" Style="{StaticResource NavButton}"
                                     GroupName="Nav"
                                     IsChecked="{Binding SelectedNav, Converter={StaticResource NavCheck}, ConverterParameter=mods}"
                                     Command="{Binding NavigateCommand}" CommandParameter="mods"/>
                        <RadioButton Content="{DynamicResource NavRoom}" Style="{StaticResource NavButton}"
                                     GroupName="Nav"
                                     IsChecked="{Binding SelectedNav, Converter={StaticResource NavCheck}, ConverterParameter=room}"
                                     Command="{Binding NavigateCommand}" CommandParameter="room"/>
                        <RadioButton Content="{DynamicResource NavLaunch}" Style="{StaticResource NavButton}"
                                     GroupName="Nav"
                                     IsChecked="{Binding SelectedNav, Converter={StaticResource NavCheck}, ConverterParameter=launch}"
                                     Command="{Binding NavigateCommand}" CommandParameter="launch"/>
                        <RadioButton Content="{DynamicResource NavDebug}" Style="{StaticResource NavButton}"
                                     GroupName="Nav"
                                     IsChecked="{Binding SelectedNav, Converter={StaticResource NavCheck}, ConverterParameter=debug}"
                                     Command="{Binding NavigateCommand}" CommandParameter="debug"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content area -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
        </Grid>
    </Grid>
</Window>