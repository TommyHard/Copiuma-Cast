<Window x:Class="Cast.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cast.Desktop"
        mc:Ignorable="d"
        Title="Copiuma.Cast — GameBridge тест" Height="560" Width="860">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Манифест -->
        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <TextBlock Text="Манифест:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button x:Name="LoadButton" Content="Загрузить" Width="90" DockPanel.Dock="Right"
                    Margin="8,0,0,0" Click="LoadButton_Click"/>
            <Button x:Name="BrowseButton" Content="Обзор…" Width="80" DockPanel.Dock="Right"
                    Click="BrowseButton_Click"/>
            <TextBox x:Name="ManifestPathBox" VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- Статус -->
        <TextBlock x:Name="StatusText" Grid.Row="1" Margin="0,0,0,8"
                   Text="Манифест не загружен." Foreground="#555"/>

        <!-- Список событий -->
        <ListBox x:Name="EventsList" Grid.Row="2" Margin="0,0,0,8">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Width="220"/>
                        <TextBlock Text="{Binding Id}" Foreground="#888" Width="180"/>
                        <TextBlock Text="{Binding Category}" Foreground="#888" Width="120"/>
                        <TextBlock Text="{Binding CostCoins, StringFormat='coins: {0}'}" Width="80"/>
                        <TextBlock Text="{Binding CooldownMs, StringFormat='cd: {0} ms'}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Отправка -->
        <DockPanel Grid.Row="3" LastChildFill="True" Margin="0,0,0,8">
            <TextBlock Text="Ник:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="UsernameBox" Width="140" Text="TestViewer" DockPanel.Dock="Left"
                     VerticalContentAlignment="Center" Margin="0,0,12,0"/>
            <Button x:Name="FireButton" Content="Отправить событие" Width="160" DockPanel.Dock="Right"
                    Margin="8,0,0,0" Click="FireButton_Click"/>
            <TextBlock Text="Параметры (key=value;key=value):" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="ArgsBox" VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- Лог -->
        <TextBox x:Name="LogBox" Grid.Row="4" IsReadOnly="True" FontFamily="Consolas"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                 Background="#1e1e1e" Foreground="#d4d4d4"/>
    </Grid>
</Window>
