<UserControl x:Class="Cast.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="500" d:DesignWidth="800">
    <Grid>
        <Grid Style="{StaticResource AnimatedBackgroundStyle}">
            <Grid.Effect>
                <BlurEffect Radius="7" KernelType="Gaussian" />
            </Grid.Effect>
        </Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
            <!-- Logo / Title -->
            <TextBlock Text="{DynamicResource AppTitle}" FontSize="32" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="{DynamicResource LoginSubtitle}" FontSize="14"
                       Foreground="{DynamicResource FgSecondaryBrush}" HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <Button Content="{DynamicResource LoginButton}"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding LoginCommand}"
                    HorizontalAlignment="Stretch" Height="44" FontSize="15"/>

            <!-- Language switcher -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button Content="English" Style="{StaticResource SecondaryButton}"
                        Command="{Binding SwitchLanguageCommand}" CommandParameter="en"
                        Margin="0,0,8,0" Padding="12,6"/>
                <Button Content="Русский" Style="{StaticResource SecondaryButton}"
                        Command="{Binding SwitchLanguageCommand}" CommandParameter="ru"
                        Padding="12,6"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>