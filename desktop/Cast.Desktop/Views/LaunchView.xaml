<UserControl x:Class="Cast.Desktop.Views.LaunchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="500" d:DesignWidth="600">
    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{DynamicResource LaunchTitle}" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- Exe path -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource LaunchExe}" Foreground="{DynamicResource FgSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <DockPanel Margin="0,0,0,12">
                    <Button Content="{DynamicResource ModsBrowse}" DockPanel.Dock="Right"
                            Style="{StaticResource SecondaryButton}" Command="{Binding BrowseExeCommand}"
                            Padding="10,4" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding GameExePath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                </DockPanel>

                <TextBlock Text="{DynamicResource LaunchManifest}" Foreground="{DynamicResource FgSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <DockPanel>
                    <Button Content="{DynamicResource ModsBrowse}" DockPanel.Dock="Right"
                            Style="{StaticResource SecondaryButton}" Command="{Binding BrowseManifestCommand}"
                            Padding="10,4" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding ManifestPath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Launch / Stop -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="{DynamicResource LaunchStart}" Style="{StaticResource AccentButton}"
                    Command="{Binding LaunchCommand}" Padding="16,8" Margin="0,0,8,0"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}"/>
            <Button Content="{DynamicResource LaunchStop}" Style="{StaticResource SecondaryButton}"
                    Command="{Binding StopCommand}" Padding="16,8"
                    IsEnabled="{Binding IsRunning}"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusText}" FontSize="13"
                   Foreground="{DynamicResource FgSecondaryBrush}" Margin="0,0,0,8"/>

        <!-- Log -->
        <TextBox Grid.Row="4" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                 Background="{DynamicResource BgTertiaryBrush}"
                 Foreground="{DynamicResource FgSecondaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"/>
    </Grid>
</UserControl>
