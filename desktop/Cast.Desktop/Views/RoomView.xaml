<UserControl x:Class="Cast.Desktop.Views.RoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="500" d:DesignWidth="600"
             Loaded="OnLoaded">
    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{DynamicResource RoomTitle}" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- Create room form (visible when no room) -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                Visibility="{Binding HasRoom, Converter={StaticResource InvertBoolToVis}}">
            <StackPanel>
                <TextBlock Text="{DynamicResource RoomName}" Foreground="{DynamicResource FgSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBox Text="{Binding RoomTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource RoomGame}" Foreground="{DynamicResource FgSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding AvailableGames}" DisplayMemberPath="GameName"
                          SelectedValuePath="GameId" SelectedValue="{Binding GameId}"
                          Margin="0,0,0,12"
                          Background="{DynamicResource BgTertiaryBrush}"
                          Foreground="{DynamicResource FgPrimaryBrush}"/>

                <TextBlock Text="{DynamicResource RoomViewerLimit}" Foreground="{DynamicResource FgSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBox Text="{Binding ViewerLimit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"
                         Width="120" HorizontalAlignment="Left"/>

                <Button Content="{DynamicResource RoomCreate}" Style="{StaticResource AccentButton}"
                        Command="{Binding CreateRoomCommand}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Active room panel (visible when has room) -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                Visibility="{Binding HasRoom, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="{DynamicResource RoomCode}" FontSize="14"
                               Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RoomCode}" FontSize="24" FontWeight="Bold" Margin="8,0"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{DynamicResource RoomCopyCode}" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CopyCodeCommand}" Padding="10,4" Margin="0,0,6,0"/>
                        <Button Content="{DynamicResource RoomCopyLink}" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CopyLinkCommand}" Padding="10,4"/>
                    </StackPanel>
                </DockPanel>

                <!-- Invite -->
                <DockPanel Margin="0,0,0,12">
                    <Button Content="{DynamicResource RoomInvite}" DockPanel.Dock="Right"
                            Style="{StaticResource AccentButton}" Command="{Binding InviteCommand}"
                            Padding="12,6" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding InviteIdentifier, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                </DockPanel>

                <Button Content="{DynamicResource RoomClose}" Style="{StaticResource SecondaryButton}"
                        Command="{Binding CloseRoomCommand}" HorizontalAlignment="Left"
                        Foreground="{DynamicResource ErrorBrush}" Padding="12,6"/>

                <!-- Громкость медиа (синхронизируется с оверлеем) -->
                <DockPanel Margin="0,12,0,0">
                    <TextBlock Text="{DynamicResource RoomMediaVolume}" DockPanel.Dock="Left" Margin="0,0,8,0"
                               VerticalAlignment="Center" Foreground="{DynamicResource FgSecondaryBrush}"/>
                    <TextBlock Text="{Binding MediaVolume}" DockPanel.Dock="Right" Width="32" Margin="8,0,0,0"
                               VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <Slider Minimum="0" Maximum="100" Value="{Binding MediaVolume}"
                            VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>
                </DockPanel>

                <!-- Connected viewers -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                    <TextBlock Text="{DynamicResource RoomMembers}" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource RoomOnline}" Margin="12,0,4,0"
                               Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding OnlineCount}" Foreground="{DynamicResource AccentBrush}"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource RoomGrantAmount}" Margin="16,0,4,0"
                               Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding GrantAmount, UpdateSourceTrigger=PropertyChanged}"
                             Width="70" VerticalContentAlignment="Center"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Members}" MaxHeight="160" Margin="0,0,0,4"
                         Background="{DynamicResource BgTertiaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource FgPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                    <TextBlock Text="{Binding Role}" VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="{DynamicResource FgSecondaryBrush}" FontSize="11"/>
                                    <Button Content="{DynamicResource RoomGrant}" Padding="6,2" Margin="0,0,4,0"
                                            Command="{Binding DataContext.GrantCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="Streamer">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="{DynamicResource RoomKick}" Padding="6,2" Margin="0,0,4,0"
                                            Command="{Binding DataContext.KickCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="Streamer">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="{DynamicResource RoomBlock}" Padding="6,2"
                                            Command="{Binding DataContext.BlockCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="Streamer">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Game events: enable/disable per session -->
                <TextBlock Text="{DynamicResource RoomEvents}" FontWeight="SemiBold" Margin="0,16,0,4"
                           Foreground="{DynamicResource FgPrimaryBrush}"/>
                <ListBox ItemsSource="{Binding Events}" MaxHeight="160"
                         Background="{DynamicResource BgTertiaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="False" Margin="4,2">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource FgPrimaryBrush}"/>
                                <TextBlock Text="{Binding CostCoins}" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentBrush}" FontSize="11"/>
                                <Button DockPanel.Dock="Right" Padding="8,2"
                                        Command="{Binding DataContext.ToggleEventCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Setter Property="Content" Value="{DynamicResource EventDisable}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                    <Setter Property="Content" Value="{DynamicResource EventEnable}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource FgSecondaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Bets -->
                <TextBlock Text="{DynamicResource BetsTitle}" FontWeight="SemiBold" Margin="0,16,0,4"
                           Foreground="{DynamicResource FgPrimaryBrush}"/>
                <StackPanel Margin="0,0,0,6">
                    <TextBox Text="{Binding NewBetTitle, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{DynamicResource BetQuestion}" Margin="0,0,0,4"
                             VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding NewBetOutcomes, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{DynamicResource BetOutcomes}" Margin="0,0,0,4"
                             VerticalContentAlignment="Center"/>
                    <DockPanel>
                        <TextBlock Text="{DynamicResource BetDuration}" DockPanel.Dock="Left" Margin="0,0,6,0"
                                   VerticalAlignment="Center" Foreground="{DynamicResource FgSecondaryBrush}"/>
                        <Button Content="{DynamicResource BetCreate}" DockPanel.Dock="Right"
                                Style="{StaticResource AccentButton}" Command="{Binding CreateBetCommand}"
                                Padding="10,4"/>
                        <TextBox Text="{Binding NewBetDuration, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" HorizontalAlignment="Left"/>
                    </DockPanel>
                </StackPanel>

                <ListBox ItemsSource="{Binding Bets}" MaxHeight="220"
                         Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" Padding="8" CornerRadius="6"
                                    Background="{DynamicResource BgTertiaryBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource FgPrimaryBrush}"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ClosesAtText}" Margin="8,0,0,0"
                                                       VerticalAlignment="Center" FontSize="11"
                                                       Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Text="{Binding Status}" Margin="8,0,0,0"
                                                       VerticalAlignment="Center" FontSize="11"
                                                       Foreground="{DynamicResource FgSecondaryBrush}"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding Outcomes}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel LastChildFill="False" Margin="0,1">
                                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource FgPrimaryBrush}"/>
                                                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"
                                                               Foreground="{DynamicResource FgSecondaryBrush}"
                                                               Text="{Binding Pool, StringFormat='Пул: {0}'}"/>
                                                    <Button Content="{DynamicResource BetResolve}" DockPanel.Dock="Right"
                                                            Padding="8,2" Style="{StaticResource SecondaryButton}"
                                                            Visibility="{Binding CanResolve, Converter={StaticResource BoolToVis}}"
                                                            Command="{Binding DataContext.ResolveBetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="{DynamicResource BetCancel}" HorizontalAlignment="Left" Margin="0,4,0,0"
                                            Padding="8,2" Foreground="{DynamicResource ErrorBrush}"
                                            Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding DataContext.CancelBetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding ResultText}" Margin="0,4,0,0" TextWrapping="Wrap"
                                               FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusText}" FontSize="12"
                   Foreground="{DynamicResource FgSecondaryBrush}" Margin="0,0,0,8"/>

        <!-- Log -->
        <ListBox Grid.Row="3" ItemsSource="{Binding Log}"
                 Background="{DynamicResource BgTertiaryBrush}"
                 Foreground="{DynamicResource FgSecondaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" FontFamily="Consolas" FontSize="12"/>
    </Grid>
</UserControl>