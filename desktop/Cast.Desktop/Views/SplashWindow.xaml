<Window x:Class="Cast.Desktop.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        WindowStyle="None" 
        ResizeMode="NoResize" 
        Background="Black" 
        ShowInTaskbar="False" 
        Topmost="True"
        WindowStartupLocation="CenterScreen" 
        Width="640" Height="360"
        x:Name="SplashScreenPanel"
        MouseLeftButtonDown="SplashScreenMove_MouseDown">

    <Border BorderBrush="#9BDF1E" 
            BorderThickness="5">

        <Grid>
            <Grid Style="{StaticResource AnimatedBackgroundStyle}">
                <Grid.Effect>
                    <BlurEffect Radius="10" 
                                KernelType="Gaussian" />
                </Grid.Effect>
            </Grid>

            <Button Width="30" Height="30"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="10"
                    Style="{StaticResource ControlButtonStyle}"
                    Content="{StaticResource CloseButton}"
                    Click="CloseButton_Click"/>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <Border x:Name="PlayerContainer"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="180" Height="180"
                        CornerRadius="122">

                    <Grid>
                        <Border x:Name="ContentMask"
                                Background="#000000"
                                CornerRadius="{Binding ElementName=PlayerContainer, Path=CornerRadius}" />

                        <StackPanel>
                            <StackPanel.OpacityMask>
                                <VisualBrush Visual="{Binding ElementName=ContentMask}" />
                            </StackPanel.OpacityMask>

                            <Image x:Name="Player"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Stretch="UniformToFill" 
                                   gif:AnimationBehavior.SourceUri="pack://application:,,,/Cast.Desktop;component/Assets/SplashScreen/splash-screen.gif"
                                   gif:AnimationBehavior.RepeatBehavior="1x"
                                   gif:AnimationBehavior.Loaded="OnAnimationLoaded" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="{StaticResource AppLoading}"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Foreground="White"
                           FontSize="21"
                           Margin="0 15 0 0"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>