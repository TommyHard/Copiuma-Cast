<UserControl x:Class="Cast.Desktop.Views.ModManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="500" d:DesignWidth="600">
    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource ModsTitle}" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource FgPrimaryBrush}" VerticalAlignment="Center"/>
            <Button Content="{DynamicResource ModsRefresh}" Style="{StaticResource SecondaryButton}"
                    Command="{Binding RefreshCommand}" HorizontalAlignment="Right" Padding="12,6"/>
        </DockPanel>

        <!-- Mod list -->
        <ListBox Grid.Row="1" ItemsSource="{Binding AvailableMods}"
                 SelectedItem="{Binding SelectedMod}" Margin="0,0,0,12"
                 Background="{DynamicResource BgTertiaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" Margin="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding GameName}" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{DynamicResource FgPrimaryBrush}"/>
                                <TextBlock Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12">
                                    <Run Text="Server: "/><Run Text="{Binding ServerVersion}"/>
                                    <Run Text=" | Installed: "/><Run Text="{Binding InstalledVersion, TargetNullValue='—'}"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"
                                       Text="Installed"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Game directory -->
        <DockPanel Grid.Row="2" Margin="0,0,0,8" DataContext="{Binding SelectedMod}">
            <TextBlock Text="{DynamicResource ModsGameDir}" VerticalAlignment="Center"
                       Foreground="{DynamicResource FgSecondaryBrush}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource ModsBrowse}" DockPanel.Dock="Right"
                    Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="8,0,0,0"
                    Click="BrowseGameDir_Click"/>
            <TextBox Text="{Binding GameDirectory, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- Action buttons -->
        <WrapPanel Grid.Row="3" Margin="0,0,0,8">
            <Button Content="{DynamicResource ModsInstallAll}" Style="{StaticResource AccentButton}"
                    Command="{Binding InstallCommand}" CommandParameter="All"
                    Margin="0,0,6,0" Padding="12,6" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"/>
            <Button Content="{DynamicResource ModsInstallLibs}" Style="{StaticResource SecondaryButton}"
                    Command="{Binding InstallCommand}" CommandParameter="LibrariesOnly"
                    Margin="0,0,6,0" Padding="12,6"/>
            <Button Content="{DynamicResource ModsInstallMod}" Style="{StaticResource SecondaryButton}"
                    Command="{Binding InstallCommand}" CommandParameter="ModOnly"
                    Margin="0,0,6,0" Padding="12,6"/>
            <Button Content="{DynamicResource ModsUninstall}" Style="{StaticResource SecondaryButton}"
                    Command="{Binding UninstallCommand}" Margin="0,0,6,0" Padding="12,6"/>
            <Button Content="{DynamicResource ModsVerify}" Style="{StaticResource SecondaryButton}"
                    Command="{Binding VerifyCommand}" Padding="12,6"/>
        </WrapPanel>

        <!-- Status / Progress -->
        <StackPanel Grid.Row="4">
            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Margin="0,0,0,6"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource BgTertiaryBrush}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding StatusText}" FontSize="12"
                       Foreground="{DynamicResource FgSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
