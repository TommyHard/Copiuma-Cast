{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api": {
        "ClusterId": "api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "hubs": {
        "ClusterId": "api",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },
      "swagger": {
        "ClusterId": "api",
        "Match": {
          "Path": "/swagger/{**catch-all}"
        }
      },
      "files": {
        "ClusterId": "minio",
        "Match": {
          "Path": "/files/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/files"
          }
        ]
      }
    },
    "Clusters": {
      "api": {
        "Destinations": {
          "primary": {
            "Address": "http://cast-api:8080/"
          }
        }
      },
      "minio": {
        "Destinations": {
          "primary": {
            "Address": "http://minio:9000/"
          }
        }
      }
    }
  },
  "Seq": {
    "ServerUrl": ""
  }
}